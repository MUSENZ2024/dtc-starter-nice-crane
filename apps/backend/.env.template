STORE_CORS=http://localhost:8000
ADMIN_CORS=http://localhost:9000
AUTH_CORS=http://localhost:8000,http://localhost:9000
JWT_SECRET=replace-with-a-long-random-secret
COOKIE_SECRET=replace-with-a-different-long-random-secret
DATABASE_URL=
DB_NAME=medusa-backend
MEDUSA_BACKEND_URL=http://localhost:9000
DISABLE_MEDUSA_ADMIN=false

# Stripe payment provider
# Secret key from Stripe Dashboard > Developers > API keys.
STRIPE_API_KEY=
# Required for deployed webhook handling. Local checkout can run without it.
STRIPE_WEBHOOK_SECRET=
# Set true if orders should be captured immediately instead of authorized for manual capture.
STRIPE_CAPTURE=false
# Keep true to let Stripe's Payment Element surface supported rich payment methods.
STRIPE_AUTOMATIC_PAYMENT_METHODS=true
